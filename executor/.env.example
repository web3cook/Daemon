# ── Chain (Arbitrum Sepolia) ───────────────────────────────────────────────────
RPC_URL=https://sepolia-rollup.arbitrum.io/rpc
CHAIN_ID=421614

# ── Agent identity ─────────────────────────────────────────────────────────────
# Wallet that signs and submits Subscriptions.execute() on behalf of this agent.
PRIVATE_KEY=0x<your_agent_private_key>
# ERC-8004 agentId this executor runs for.
AGENT_ID=1
# Skip execution if the agent's ValidationRegistry score drops below this.
MIN_TRUST_SCORE=50

# ── Contracts (from contract-1/deployments/arbitrum-sepolia.json) ─────────────
SUBSCRIPTIONS_ADDR=0xECF4449851087EeD9f2e1456D6C1d8dC20e8Af38
VALIDATION_REGISTRY_ADDR=0x4c5DdDF412c79c177566540C4Ab2AbBa6E3d1b54
AGGREGATOR_ADDR=0xC34AD1AaEfA81d82937452eb38842325D010984B

# ── Tokens ─────────────────────────────────────────────────────────────────────
USDC_ADDR=0xB88f8299447FB6a28EF720Dea150f695953fdA11
OUTPUT_TOKEN_ADDR=0x2439Fbf1FEd2b48C94A949c56341f2eA26f2aad4

# ── Scheduler ──────────────────────────────────────────────────────────────────
SCHEDULER_INTERVAL_SECS=60

# ── Gas ceiling (PRD section 9.1) ──────────────────────────────────────────────
MAX_GAS_GWEI=0.1

# ── CoinCap Pro - live price feed ──────────────────────────────────────────────
# Falls back to mock price ($3400) if unset.
COINCAP_KEY=your_coincap_key_here

# ── Claude AI safety oracle ────────────────────────────────────────────────────
# If set: Claude gates each execution (anomaly detection, gas check, slippage tuning)
# If unset: falls back to deterministic rules from PRD section 9.1
ANTHROPIC_API_KEY=sk-ant-...

# ── x402 facilitator ───────────────────────────────────────────────────────────
# If true, prices/routes via the local mock server (see ../agents) at MOCK_X402_PORT.
# If false, set X402_PRICE_URL / X402_ROUTING_URL to a real facilitator.
MOCK_X402_ENABLED=true
MOCK_X402_PORT=8402
# X402_PRICE_URL=https://...
# X402_ROUTING_URL=https://...

# ── Shared database (reads active subscriptions, same DB as ../backend) ───────
DATABASE_URL=postgres://localhost:5432/sip_daemon
