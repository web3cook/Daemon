# ── Chain (Arbitrum Sepolia) ───────────────────────────────────────────────────
RPC_URL=https://sepolia-rollup.arbitrum.io/rpc
CHAIN_ID=421614

# ── Agent identity ─────────────────────────────────────────────────────────────
# Used to build the chain clients for payment-intent/balance reads and (for the
# executor) to sign Subscriptions.execute() and x402 settlement transactions.
PRIVATE_KEY=0x<your_agent_private_key>
# ERC-8004 agentId the executor runs for (DCA agent = 16).
AGENT_ID=16
# Executor: skip execution if the agent's ValidationRegistry score drops below this.
MIN_TRUST_SCORE=50

# ── Contracts (from contracts/deployments/arbitrum-sepolia.json) ──────────────
SUBSCRIPTIONS_ADDR=0xdeA11fC11A86a2c3bD70F5D37087C869F0bf88Ed
SERVICE_FACTORY_ADDR=0x91F9f2d566098EB22642D2f0a692352f45DD8bd3
VALIDATION_REGISTRY_ADDR=0xb3E35540bb8862ac3b4A80Ac80ecbe7eC90b185b
AGGREGATOR_ADDR=0xe4CB3caAA49c61F2593370138DEC7fdfd0643Cf7

# ── Tokens ─────────────────────────────────────────────────────────────────────
USDC_ADDR=0x6Fd5c8aF495B2811288B9491932dc2bC079a9691
OUTPUT_TOKEN_ADDR=0xe8D355544f832B731D7Bd040B8D6d4eE959b6401

# ── Indexer ────────────────────────────────────────────────────────────────────
INDEXER_START_BLOCK=277075700
INDEXER_POLL_SECS=20

# ── Executor: gas ceiling (PRD §9.1) ───────────────────────────────────────────
MAX_GAS_GWEI=0.1

# ── Executor: scheduler tick interval ──────────────────────────────────────────
SCHEDULER_INTERVAL_SECS=30

# ── Claude AI — agent card blurb ───────────────────────────────────────────────
# If unset, falls back to a deterministic blurb.
ANTHROPIC_API_KEY=sk-ant-...

# ── Daemon API server (PostgreSQL-backed REST API for the frontend) ───────────
DATABASE_URL=postgres://localhost:5432/sip_daemon
API_PORT=3001
CORS_ORIGIN=http://localhost:3000
