# ── Chain ──────────────────────────────────────────────────────────────────────
RPC_URL=https://sepolia-rollup.arbitrum.io/rpc
CHAIN_ID=421614

# ── Agent identity ─────────────────────────────────────────────────────────────
PRIVATE_KEY=0x<your_agent_private_key>
AGENT_ID=1
MIN_TRUST_SCORE=50

# ── Contracts  (from contract-1/deployments/arbitrum-sepolia.json) ─────────────
SUBSCRIPTIONS_ADDR=0xECF4449851087EeD9f2e1456D6C1d8dC20e8Af38
VALIDATION_REGISTRY_ADDR=0x4c5DdDF412c79c177566540C4Ab2AbBa6E3d1b54
AGGREGATOR_ADDR=0xC34AD1AaEfA81d82937452eb38842325D010984B

# ── Tokens ─────────────────────────────────────────────────────────────────────
USDC_ADDR=0xB88f8299447FB6a28EF720Dea150f695953fdA11
OUTPUT_TOKEN_ADDR=0x2439Fbf1FEd2b48C94A949c56341f2eA26f2aad4

# ── Subscriptions the agent watches (comma-sep bytes32 IDs) ────────────────────
SUBSCRIPTION_IDS=0x9dd1f792f535cc9d1533021dfcd3283c463f734813670e18c961f7d86522789f

# ── Scheduler ──────────────────────────────────────────────────────────────────
SCHEDULER_INTERVAL_SECS=60

# ── Gas ceiling (PRD §9.1) ─────────────────────────────────────────────────────
MAX_GAS_GWEI=0.1

# ── CoinCap Pro — live price feed ─────────────────────────────────────────────
# Same key used by backend/seed.py. Falls back to mock price ($3400) if unset.
COINCAP_KEY=your_coincap_key_here

# ── Claude AI safety oracle ────────────────────────────────────────────────────
# If set: Claude gates each execution (anomaly detection, gas check, slippage tuning)
# If unset: falls back to deterministic rules from PRD §9.1
ANTHROPIC_API_KEY=sk-ant-...

# ── x402 mock server ───────────────────────────────────────────────────────────
MOCK_X402_ENABLED=true
MOCK_X402_PORT=8402
# Uncomment to point at a real x402 facilitator:
# X402_PRICE_URL=https://...
# X402_ROUTING_URL=https://...
