# Root secrets for docker-compose.yml / docker-compose.agents.yml.
# Copy to `.env` and fill in real values — `.env` is gitignored.

# Shared signer for backend/executor/agents (Arbitrum Sepolia testnet key).
PRIVATE_KEY=0x<your_private_key>

# CoinCap Pro live price feed (shared by executor + agents). Optional —
# falls back to a mock price if unset.
COINCAP_KEY=your_coincap_key_here

# Claude AI safety/risk oracle (shared by backend + agents). Optional —
# falls back to deterministic rules if unset.
ANTHROPIC_API_KEY=sk-ant-...

# WalletConnect project id, baked into the frontend bundle at build time.
NEXT_PUBLIC_WC_PROJECT_ID=your_walletconnect_project_id
