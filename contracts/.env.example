# ── Shared ────────────────────────────────────────────────────────────────────
PRIVATE_KEY=0x...
ARBISCAN_API_KEY=

# ── Arbitrum Sepolia (testnet) ─────────────────────────────────────────────────
ARBITRUM_SEPOLIA_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc

# ── Arbitrum One (mainnet) ────────────────────────────────────────────────────
ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc

# ── Mainnet-only: set before running DeployMainnet.s.sol ─────────────────────
# Hot wallet the agent backend uses to sign execute() transactions
EXECUTOR_ADDRESS=0x...

# Multisig or EOA that receives protocol fees
TREASURY_ADDRESS=0x...

# DEX router — Uniswap V3 SwapRouter02 on Arbitrum One:
AGGREGATOR_ADDRESS=0x68b3465833fb72A70ecDF485E0e4C7bD8665Fc45

# Agent identity card URL
AGENT_CARD_URI=https://your-domain.com/.well-known/agent.json

# Arbitrum One token addresses (stable — only change if bridging to another chain)
WETH_ADDRESS=0x82aF49447D8a07e3bd95BD0d56f35241523fBab1
WBTC_ADDRESS=0x2f2a2543B76A4166549F7aaB2e75Bef0aefC5B0f
ARB_ADDRESS=0x912CE59144191C1204E64559FE8253a0e49E6548

# ── Set after deployment ──────────────────────────────────────────────────────
SUBSCRIPTION_ID=0x...
