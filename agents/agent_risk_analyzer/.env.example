# ── Chain ──────────────────────────────────────────────────────────────────────
RPC_URL=https://sepolia-rollup.arbitrum.io/rpc
CHAIN_ID=421614

# ── Agent identity ─────────────────────────────────────────────────────────────
# Wallet whose address is reported as the payee in the x402 risk-report response,
# and which submits the on-chain USDC.transferFrom() settlement for /v1/risk-report.
PRIVATE_KEY=0x<your_agent_private_key>

# ── Tokens ─────────────────────────────────────────────────────────────────────
USDC_ADDR=0xB88f8299447FB6a28EF720Dea150f695953fdA11

# ── x402 server ─────────────────────────────────────────────────────────────────
MOCK_X402_PORT=8403

# Price of one POST /v1/risk-report call, in USDC smallest units (6 decimals).
# 40000 = 0.04 USDC.
RISK_REPORT_PRICE_USDC=40000

# ── CoinCap Pro - live price feed ──────────────────────────────────────────────
# Same key used by ../agent_dca. Falls back to mock ETH price ($1647) if unset.
COINCAP_KEY=your_coincap_key_here

# ── Claude AI risk oracle ────────────────────────────────────────────────────────
# Used by /v1/risk-report to assess the wallet's holdings. Falls back to a
# deterministic concentration-based score if unset.
ANTHROPIC_API_KEY=sk-ant-...
