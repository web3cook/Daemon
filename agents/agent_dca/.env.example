# ── Chain ──────────────────────────────────────────────────────────────────────
RPC_URL=https://sepolia-rollup.arbitrum.io/rpc
CHAIN_ID=421614

# ── Agent identity ─────────────────────────────────────────────────────────────
# Wallet whose address is reported as the payee in x402 price/route/decide responses,
# and which submits the on-chain USDC.transferFrom() settlement for /v1/decide.
PRIVATE_KEY=0x<your_agent_private_key>

# ── Tokens ─────────────────────────────────────────────────────────────────────
USDC_ADDR=0xB88f8299447FB6a28EF720Dea150f695953fdA11

# ── Mock x402 server ───────────────────────────────────────────────────────────
MOCK_X402_PORT=8402

# Price of one POST /v1/decide call, in USDC smallest units (6 decimals).
# 10000 = 0.01 USDC.
DECIDE_PRICE_USDC=10000

# ── CoinCap Pro - live price feed ──────────────────────────────────────────────
# Same key used by ../executor. Falls back to mock price ($3400) if unset.
COINCAP_KEY=your_coincap_key_here

# ── Claude AI safety oracle ────────────────────────────────────────────────────
# Used by /v1/decide for the execution safety check. Falls back to a deterministic
# should_execute=true if unset.
ANTHROPIC_API_KEY=sk-ant-...
